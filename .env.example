# ────────────────────────────────────────────────────────────
# vForge — environment variables
# Copy to .env and fill in. Never commit .env.
# ────────────────────────────────────────────────────────────

# ── App ──
APP_ENV=development
APP_NAME=vForge
APP_PORT=8000
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=info

# ── Database ──
# Local Postgres via docker-compose:
DATABASE_URL=postgresql+psycopg://vforge:vforge@localhost:5432/vforge
# Hosted alternatives (Neon/Supabase): paste full connection string here

# ── LLM Providers (Tier 1 — open, recommended) ──
OLLAMA_BASE_URL=http://localhost:11434
TOGETHER_API_KEY=

# ── LLM Providers (Tier 2 — proprietary, optional, user accepts ToS) ──
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── LLM Providers (Tier 3 — custom OpenAI-compatible endpoint) ──
CUSTOM_LLM_BASE_URL=
CUSTOM_LLM_API_KEY=
CUSTOM_LLM_MODEL=

# ── Default models ──
DEFAULT_GENERATOR_MODEL=llama3.1:8b
DEFAULT_GENERATOR_PROVIDER=ollama
DEFAULT_BASE_MODEL=google/gemma-2-2b

# ── Storage ──
HF_TOKEN=
HF_DEFAULT_ORG=
GCS_BUCKET=
GOOGLE_APPLICATION_CREDENTIALS=

# ── Google Cloud / TPU ──
GCP_PROJECT_ID=
GCP_REGION=us-central1
TPU_NAME=
TPU_ZONE=us-central1-a
TPU_TYPE=v5e-4

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=vForge
